configfile: "config.yaml"

rule all:
    input:
        "results/structures_clusters/structure_nodes.csv",
        "results/structure_clusters/structure_links.csv"


# --- Detect Structural Clusters ---
rule detect_structure_clusters:
    input:
        data = "results/foldtree/structure_alignment.csv"
    output:
        nodes = "results/structures_clusters/structure_nodes.csv",
        links = "results/structure_clusters/structure_links.csv"
    benchmark:
        "results/benchmarks/detect_structure_clusters.tsv"
    conda:
        "envs/base.yaml"
    script:
        "scripts/structure_clusters.py"