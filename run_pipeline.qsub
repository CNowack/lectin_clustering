echo "=========================================="
echo "Job:       $JOB_NAME ($JOB_ID)"
echo "Host:      $(hostname)"
echo "Cores:     $NSLOTS"
echo "Start:     $(date)"
echo "=========================================="

cd /projectnb/ds596/projects/Team_2/lectin_clustering
module load miniconda
conda activate snakemake
mkdir -p logs

time snakemake \
    --cores $NSLOTS \
    --use-conda \
    --rerun-incomplete \
    -s snakefile

echo "=========================================="
echo "End:       $(date)"
echo "=========================================="